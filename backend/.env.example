# Network / server
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# Cluster strategy
# localnet | devnet | mainnet
SOLANA_CLUSTER=localnet
SOLANA_RPC_URL=http://127.0.0.1:8899
SOLANA_WS_URL=ws://127.0.0.1:8900

# Optional per-cluster program ID overrides (used by SDK)
# SSS_TOKEN_PROGRAM_ID=
# SSS_TRANSFER_HOOK_PROGRAM_ID=

# Required: active stablecoin config PDA
STABLECOIN_CONFIG=

# Required for write endpoints (/api/mint, /api/burn, /api/blacklist, ...)
AUTHORITY_KEYPAIR_PATH=/Users/your-user/.config/solana/id.json

# Optional API protection for write endpoints
API_KEY=
WRITE_RATE_LIMIT_WINDOW_MS=60000
WRITE_RATE_LIMIT_MAX=60

# Indexer persistence
INDEXER_STATE_PATH=./data/indexer-state.json

# Optional webhook delivery
WEBHOOK_URL=
WEBHOOK_SECRET=
WEBHOOK_MAX_RETRIES=3

# Optional sanctions API
SANCTIONS_API_URL=
SANCTIONS_API_KEY=
